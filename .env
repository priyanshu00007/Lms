# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
HOST=localhost
API_PREFIX=/api

# ============================================
# CLIENT CONFIGURATION
# ============================================
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb://localhost:27017/your_app_name
MONGODB_URI_TEST=mongodb://localhost:27017/your_app_name_test
MONGODB_URI_PRODUCTION=mongodb+srv://username:password@cluster.mongodb.net/production

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRATION=7d
JWT_ISSUER=your-app-name
JWT_AUDIENCE=your-app-audience

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=Your App Name
SMTP_SECURE=false

# For development/testing (Ethereal)
SMTP_HOST_DEV=smtp.ethereal.email
SMTP_PORT_DEV=587
SMTP_USERNAME_DEV=ethereal-username
SMTP_PASSWORD_DEV=ethereal-password

# ============================================
# AWS S3 / CLOUD STORAGE
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-bucket-name
AWS_CLOUDFRONT_URL=https://your-cloudfront-url.cloudfront.net

# ============================================
# STRIPE PAYMENT
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd

# ============================================
# OAUTH / SOCIAL LOGIN
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/v1/auth/facebook/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# ============================================
# SECURITY
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEY=your_encryption_key_min_32_chars

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_DIR=logs
LOG_MAX_SIZE=5m
LOG_MAX_FILES=5

# ============================================
# CACHE
# ============================================
CACHE_TTL=3600
CACHE_ENABLED=true

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp
UPLOAD_DIR=uploads

# ============================================
# PAGINATION
# ============================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ============================================
# SEARCH
# ============================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_ENABLED=false

# ============================================
# PUSH NOTIFICATIONS
# ============================================
FIREBASE_SERVER_KEY=your_firebase_server_key
FIREBASE_SENDER_ID=your_firebase_sender_id

# ============================================
# SMS (TWILIO)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ============================================
# ANALYTICS
# ============================================
GOOGLE_ANALYTICS_ID=your_ga_id
SENTRY_DSN=your_sentry_dsn
MIXPANEL_TOKEN=your_mixpanel_token

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_EMAIL_VERIFICATION=true
ENABLE_SOCIAL_LOGIN=false
ENABLE_2FA=false
ENABLE_NEWSLETTER=true
ENABLE_CHAT=false

# ============================================
# API KEYS (External Services)
# ============================================
OPENAI_API_KEY=your_openai_api_key
MAPBOX_ACCESS_TOKEN=your_mapbox_token
WEATHER_API_KEY=your_weather_api_key

# ============================================
# SEEDING
# ============================================
SEED_DB=false
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123456